# ============================================================
# CHATBOT QA AUTOMATION - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your actual values
# ============================================================

# ── Google Docs ──────────────────────────────────────────────
# The document ID from the URL:
# https://docs.google.com/document/d/DOCUMENT_ID/edit
GOOGLE_DOCUMENT_ID=your_document_id_here

# You can use GOOGLE_DOCUMENT_URL instead of GOOGLE_DOCUMENT_ID.
# GOOGLE_DOCUMENT_URL=https://docs.google.com/document/d/your_document_id_here/edit

# Path to the Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./credentials/google-service-account.json

# Google Docs table header names
DOC_COL_TEST_ID_HEADER=Test case ID
DOC_COL_TEST_STEPS_HEADER=Test Steps
DOC_COL_EXPECTED_HEADER=Expected Result
DOC_COL_ACTUAL_HEADER=Actual Result
DOC_COL_STATUS_HEADER=Status
DOC_COL_REMARK_HEADER=Remark
DOC_SCREENSHOT_IMAGE_WIDTH_PT=280

# ── Google Sheets ────────────────────────────────────────────
# The spreadsheet ID from the URL
GOOGLE_SPREADSHEET_ID=

# จำกัดจำนวนคำถามต่อ topic/table/sheet (default 100, 0 = ไม่จำกัด)
MAX_QUESTIONS_PER_TOPIC=100

# ── Transport Mode (v6) ───────────────────────────────────────
# webhook = ส่งคำถามผ่าน API (ค่าเริ่มต้น v6)
# browser = ใช้ Playwright กรอกหน้าเว็บ (โหมด v5.2)
TRANSPORT_MODE=webhook

# ── Webhook API ──────────────────────────────────────────────
# ⚠ ใส่ URL จริงเมื่อได้รับรายละเอียด API จากทีม Backend
WEBHOOK_ENABLED=true
WEBHOOK_URL=
WEBHOOK_METHOD=POST

# Authentication: none | bearer | api-key | basic
WEBHOOK_AUTH_TYPE=none
WEBHOOK_AUTH_TOKEN=

# ชื่อ field ใน request/response JSON
WEBHOOK_QUESTION_FIELD=question
WEBHOOK_RESPONSE_FIELD=answer

# Session ID (ถ้า API ต้องการ)
WEBHOOK_SESSION_ID=

# Custom payload template (JSON) — ใช้ {{question}}, {{testId}}, {{expected}}
# WEBHOOK_PAYLOAD_TEMPLATE={"message":"{{question}}","session":"{{sessionId}}"}

# Extra headers (JSON object)
# WEBHOOK_EXTRA_HEADERS={"X-Custom-Header":"value"}

# Health check endpoint (optional)
WEBHOOK_HEALTH_CHECK_URL=

# HTTP request timeout per call (ms) — ต้องน้อยกว่า QUEUE_PROCESSING_TIMEOUT_MS
WEBHOOK_REQUEST_TIMEOUT_MS=55000

# ── Message Queue ────────────────────────────────────────────
# ระยะห่างระหว่างการส่งคำถามแต่ละข้อ (ms) — default 30 วินาที
QUEUE_RATE_LIMIT_MS=60000

# Timeout การประมวลผลต่อ 1 คำถาม (ms) — default 2 นาที
QUEUE_PROCESSING_TIMEOUT_MS=120000

# ── Chatbot Website (legacy browser mode only) ───────────────
# Full URL of the chatbot web application — ใช้เมื่อ TRANSPORT_MODE=browser
CHATBOT_URL=

# CSS selector for the chat input box
CHATBOT_INPUT_SELECTOR=textarea[placeholder*="message"]

# CSS selector for the send button
CHATBOT_SEND_SELECTOR=button[type="submit"]

# CSS selector that matches all chatbot response bubbles
# The LAST matching element is used as the latest response
CHATBOT_RESPONSE_SELECTOR=article.pmx-message-item--other:not(.pmx-message-item--initial) .pmx-message-item__text

# Strategy for selecting the bubble: "last" or "newest" or "custom"
CHATBOT_BUBBLE_STRATEGY=last

# Thinking phrases to ignore before extracting text (comma-separated)
CHATBOT_THINKING_PHRASES=คิดสักครู่นะคะ,กำลังคิด,typing,...

# CSS selector for the typing/loading indicator
# Leave empty if your chatbot has no such indicator
CHATBOT_LOADING_SELECTOR=.typing-indicator

# ── Timing & Retry ───────────────────────────────────────────
# How long to wait for the chatbot to start responding (ms)
RESPONSE_WAIT_TIMEOUT=30000

# How long to wait for the chatbot to FINISH responding (ms)
RESPONSE_FINISH_TIMEOUT=60000

# Polling interval when waiting for response to stabilize (ms)
RESPONSE_POLL_INTERVAL=1500

# How many milliseconds the response text must be unchanged
# before we consider it "done"
RESPONSE_STABLE_DURATION=3000

# Maximum retry attempts per test case
MAX_RETRIES=3

# Delay between retries (ms)
RETRY_DELAY=3000
SCREENSHOT_DELAY=1000

# ── Classification & API Keys ──────────────────────────────────
# Anthropic API Key สำหรับ AI Classification Mode
ANTHROPIC_API_KEY=

# ImgBB API Key สำหรับ Sync รูป (ถ้าไม่ได้ใช้ Google Drive)
IMGBB_API_KEY=

# ระดับคะแนน 0.0 - 1.0–1) above which a result is PASS
SIMILARITY_PASS_THRESHOLD=0.65

# Similarity score (0–1) above which a result is PARTIAL (below = FAIL)
SIMILARITY_PARTIAL_THRESHOLD=0.30

# Thai/English keywords that trigger an automatic FAIL
FAIL_KEYWORDS=ไม่มีข้อมูล,ไม่พบข้อมูล,ขออภัย ไม่สามารถ,sorry i don't know,i don't have information

# ── Parallel Execution & System ──────────────────────────────
INSTANCE_ID=1
GOOGLE_API_MAX_REQUESTS_PER_MIN=50
CHECKPOINT_COMPRESS_AFTER=200

# ── Notification ─────────────────────────────────────────────
LINE_NOTIFY_TOKEN=
SLACK_WEBHOOK_URL=
NOTIFY_ON_COMPLETE=true
NOTIFY_FAIL_THRESHOLD=0.5

# ── Google Drive Integration ─────────────────────────────────
GOOGLE_DRIVE_SCREENSHOT_FOLDER_ID=

# ── Browser Settings ─────────────────────────────────────────
# Run browser in headless mode (true/false)
HEADLESS=true

# Slow down actions for debugging (ms), set 0 for production
SLOW_MO=0

# Browser viewport width
VIEWPORT_WIDTH=1280

# Browser viewport height
VIEWPORT_HEIGHT=800

# ── Paths ────────────────────────────────────────────────────
SCREENSHOTS_DIR=./screenshots
LOGS_DIR=./logs
REPORTS_DIR=./reports
